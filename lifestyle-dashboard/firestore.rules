// Firebase Firestore Security Rules – LIFEFLOW
// Copy this file to your Firebase project root and deploy with: firebase deploy --only firestore:rules
// Ensures only the authenticated owner can read/write their finances and people data.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /finances/{financeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /people/{personId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /habits/{habitId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /appointments/{appointmentId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
